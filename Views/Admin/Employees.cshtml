@model HRMS.Helpers.PaginatedList<HRMS.ViewModels.EmployeeVM>
@{
    ViewData["Title"] = "Manage Employees";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap">
    <div>
        <h2><i class="bi bi-people"></i> Employees</h2>
        <p class="text-muted mb-0">Manage employee records</p>
    </div>
    <div class="d-flex gap-2 mt-2 mt-md-0">
        <form asp-action="Employees" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Search employees..." />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="Employees" class="btn btn-outline-danger ms-1">Clear</a>
            }
        </form>
        <a asp-action="CreateEmployee" class="btn btn-primary text-nowrap">
            <i class="bi bi-person-plus"></i> Add Employee
        </a>
    </div>
</div>

<div class="card fade-in">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Employee Code</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Date of Joining</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sn = 1; }
                        @foreach (var emp in Model)
                        {
                            <tr>
                                <td>@(sn++)</td>
                                <td><span class="badge bg-secondary">@emp.EmployeeCode</span></td>
                                <td><strong>@emp.FirstName @emp.LastName</strong></td>
                                <td>@emp.Email</td>
                                <td>@emp.Department</td>
                                <td>@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-action="EditEmployee" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@emp.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>

            <partial name="_Pagination" model="Model" />

        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No Employees Found</h5>
                <p>Get started by adding your first employee.</p>
                <a asp-action="CreateEmployee" class="btn btn-primary mt-2">
                    <i class="bi bi-person-plus"></i> Add Employee
                </a>
            </div>
        }
    </div>
</div>

<!-- Modals placed completely outside all containers to avoid z-index and overflow clipping -->
@if (Model.Any())
{
    @foreach (var emp in Model)
    {
        <!-- Delete Modal -->
        <div class="modal fade" id="deleteModal-@emp.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger bg-opacity-10">
                        <h5 class="modal-title text-danger">
                            <i class="bi bi-exclamation-triangle"></i> Confirm Delete
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete <strong>@emp.FirstName @emp.LastName</strong> (@emp.EmployeeCode)?</p>
                        <p class="text-muted small">This action cannot be undone. All leave records for this employee will also be deleted.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="DeleteEmployee" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@emp.Id" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
