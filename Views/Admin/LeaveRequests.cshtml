@model HRMS.Helpers.PaginatedList<HRMS.ViewModels.LeaveRequestDetailVM>
@{
    ViewData["Title"] = "Leave Requests";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap">
    <div>
        <h2><i class="bi bi-clipboard-check"></i> Leave Requests</h2>
        <p class="text-muted mb-0">Review and manage pending leave applications</p>
    </div>
    <div class="mt-2 mt-md-0">
        <form asp-action="LeaveRequests" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Search requests..." />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="LeaveRequests" class="btn btn-outline-danger ms-1">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card fade-in">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Leave Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Days</th>
                            <th>Reason</th>
                            <th>Applied On</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@request.EmployeeName</strong><br />
                                    <small class="text-muted">@request.EmployeeCode</small>
                                </td>
                                <td>@request.Department</td>
                                <td>
                                    @switch (request.LeaveType)
                                    {
                                        case HRMS.Models.Enums.LeaveType.CasualLeave:
                                            <span class="badge bg-info">Casual</span>
                                            break;
                                        case HRMS.Models.Enums.LeaveType.SickLeave:
                                            <span class="badge bg-warning text-dark">Sick</span>
                                            break;
                                        case HRMS.Models.Enums.LeaveType.EarnedLeave:
                                            <span class="badge bg-success">Earned</span>
                                            break;
                                    }
                                </td>
                                <td>@request.FromDate.ToString("dd MMM yyyy")</td>
                                <td>@request.ToDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="fw-bold">
                                        @(request.IsHalfDay ? "0.5" : request.RequestedDaysDecimal.ToString("0.#"))
                                    </span>
                                    @if (request.IsHalfDay)
                                    {
                                        <span class="badge bg-info ms-1">Half Day</span>
                                    }
                                </td>
                                <td>
                                    <span title="@request.Reason">
                                        @(request.Reason.Length > 30 ? request.Reason.Substring(0, 30) + "..." : request.Reason)
                                    </span>
                                </td>
                                <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <button class="btn btn-sm btn-success me-1" data-bs-toggle="modal" data-bs-target="#approveModal-@request.Id" title="Approve">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@request.Id" title="Reject">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>

            <partial name="_Pagination" model="Model" />

        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-clipboard-check"></i>
                <h5>No Pending Requests</h5>
                <p>All leave requests have been processed.</p>
            </div>
        }
    </div>
</div>

<!-- Modals placed completely outside all containers to avoid z-index and overflow clipping -->
@if (Model.Any())
{
    @foreach (var request in Model)
    {
        <!-- Approve Modal -->
        <div class="modal fade" id="approveModal-@request.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-action="ApproveLeave" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="leaveRequestId" value="@request.Id" />
                        <div class="modal-header bg-success bg-opacity-10">
                            <h5 class="modal-title text-success">
                                <i class="bi bi-check-circle"></i> Approve Leave
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <strong>Employee:</strong> @request.EmployeeName (@request.EmployeeCode)<br />
                                <strong>Type:</strong> @request.LeaveType<br />
                                <strong>Duration:</strong> @request.FromDate.ToString("dd MMM") - @request.ToDate.ToString("dd MMM yyyy") (@request.RequestedDays days)<br />
                                <strong>Reason:</strong> @request.Reason
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Remarks (Optional)</label>
                                <textarea name="adminRemarks" class="form-control" rows="2" placeholder="Add remarks..."></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg"></i> Approve
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Reject Modal -->
        <div class="modal fade" id="rejectModal-@request.Id" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-action="RejectLeave" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="leaveRequestId" value="@request.Id" />
                        <div class="modal-header bg-danger bg-opacity-10">
                            <h5 class="modal-title text-danger">
                                <i class="bi bi-x-circle"></i> Reject Leave
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <strong>Employee:</strong> @request.EmployeeName (@request.EmployeeCode)<br />
                                <strong>Type:</strong> @request.LeaveType<br />
                                <strong>Duration:</strong> @request.FromDate.ToString("dd MMM") - @request.ToDate.ToString("dd MMM yyyy") (@request.RequestedDays days)<br />
                                <strong>Reason:</strong> @request.Reason
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Reason for Rejection (Optional)</label>
                                <textarea name="adminRemarks" class="form-control" rows="2" placeholder="Add reason..."></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-x-lg"></i> Reject
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
