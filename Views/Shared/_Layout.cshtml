<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="bi bi-building"></i> HRMS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Employees">
                                    <i class="bi bi-people"></i> Employees
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="LeaveRequests">
                                    <i class="bi bi-clipboard-check"></i> Leave Requests
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="LeaveHistory">
                                    <i class="bi bi-clock-history"></i> Leave History
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Employee"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="ApplyLeave">
                                    <i class="bi bi-calendar-plus"></i> Apply Leave
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="LeaveHistory">
                                    <i class="bi bi-clock-history"></i> Leave History
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="LeaveBalance">
                                    <i class="bi bi-pie-chart"></i> Leave Balance
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text text-muted">
                                        <small>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
        {
            var isSuccess = TempData["SuccessMessage"] != null;
            var message = isSuccess ? TempData["SuccessMessage"] : TempData["ErrorMessage"];
            var iconClass = isSuccess ? "bi-check-circle text-success" : "bi-exclamation-circle text-danger";
            var title = isSuccess ? "Success" : "Error";

            <div class="modal fade" id="globalMessageModal" tabindex="-1" aria-labelledby="globalMessageModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content text-center p-4 border-0 shadow-lg">
                        <div class="modal-body">
                            <i class="bi @iconClass" style="font-size: 4rem;"></i>
                            <h3 class="mt-3 mb-2 fw-bold" id="globalMessageModalLabel">@title</h3>
                            <p class="fs-5 text-muted mb-4">@message</p>
                            <button type="button" class="btn btn-primary px-4 py-2" data-bs-dismiss="modal">Continue</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="footer mt-auto py-3 bg-dark text-light">
        <div class="container text-center">
            <span class="text-muted">&copy; @DateTime.Now.Year HRMS - Leave Management System</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var modalEl = document.getElementById('globalMessageModal');
            if (modalEl) {
                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            }

            // AJAX Search and Pagination
            var searchForms = document.querySelectorAll('form[action*="Employees"], form[action*="LeaveRequests"], form[action*="LeaveHistory"]');
            searchForms.forEach(function(form) {
                var input = form.querySelector('input[name="searchString"]');
                if (!input) return;

                var timeout = null;
                input.addEventListener('input', function() {
                    clearTimeout(timeout);
                    timeout = setTimeout(function() {
                        var url = new URL(window.location.href);
                        url.searchParams.set('searchString', input.value);
                        url.searchParams.delete('pageNumber'); // Reset to page 1
                        fetchAndUpdateTable(url.toString());
                    }, 300); // 300ms debounce
                });

                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    var url = new URL(window.location.href);
                    url.searchParams.set('searchString', input.value);
                    url.searchParams.delete('pageNumber');
                    fetchAndUpdateTable(url.toString());
                });
            });

            document.body.addEventListener('click', function(e) {
                if (e.target.matches('.pagination .page-link')) {
                    e.preventDefault();
                    fetchAndUpdateTable(e.target.href);
                }
            });

            function fetchAndUpdateTable(url) {
                var card = document.querySelector('.card.fade-in');
                if (!card) return;
                
                card.style.opacity = '0.5'; // Visual feedback
                
                fetch(url)
                    .then(response => response.text())
                    .then(html => {
                        var parser = new DOMParser();
                        var doc = parser.parseFromString(html, 'text/html');
                        var newCard = doc.querySelector('.card.fade-in');
                        
                        if (newCard) {
                            card.innerHTML = newCard.innerHTML;
                        }
                        card.style.opacity = '1';
                        
                        // Update URL without page reload
                        window.history.replaceState({}, '', url);
                    })
                    .catch(() => {
                        window.location.href = url; // Fallback
                    });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
